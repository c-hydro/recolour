{
  "algorithm": {
    "name": "Application for downloading Copernicus CLMS Soil Water Index files",
    "version": "1.2.0",
    "release": "2026-06-15"
  },
  "logging": {
    "folder": "/hydro/log/copernicus",
    "filename": "copernicus_swi_downloader.log",
    "level": "INFO",
    "rotate_daily": true
  },
  "lock": {
    "folder": "/hydro/lock/copernicus",
    "basename": "copernicus_swi_downloader_",
    "max_slots": 1
  },
  "product": {
    "name": "swi_global_12.5km_daily_v4",
    "catalog_csv": "https://s3.waw3-1.cloudferro.com/swift/v1/CatalogueCSV/bio-geophysical/soil_water_index/swi_global_12.5km_daily_v4/swi_global_12.5km_daily_v4_cog.csv",
    "variables": [
      "SWI001",
      "SWI005",
      "SWI010",
      "SWI015",
      "SWI020",
      "SWI040"
    ],
    "exclude_variables": [
      "QFLAG",
      "SSF"
    ],
    "notes": "Requested T1, T5, T10, T20, T30, T40. Copernicus V4 has no SWI030; using SWI015 as the additional available intermediate layer, and SWI020/SWI040 around T30."
  },
  "spatial": {
    "bounding_box": [
      6.0,
      36.0,
      19.0,
      47.5
    ]
  },
  "time": {
    "time_start": null,
    "time_end": null
  },
  "downloader": {
    "data_folder": "/hydro/data/data_dynamic/source/obs/satellite/copernicus/swi/{variable}/{time_step:%Y/%m/%d}",
    "raw_folder": "/hydro/data/data_dynamic/source/obs/satellite/copernicus/swi/{time_step:%Y/%m/%d}/raw",
    "filename_template": "copernicus_{variable}_{time_step:%Y%m%d}.tif",
    "n_days": 10,
    "reference_time_round_to_day": true,
    "overwrite": false,
    "remove_raw_file": false
  },
  "output": {
    "apply_scale": true,
    "scale_factor": 0.5,
    "source_nodata": 255,
    "target_nodata": -9999.0,
    "dtype": "float32"
  }
}