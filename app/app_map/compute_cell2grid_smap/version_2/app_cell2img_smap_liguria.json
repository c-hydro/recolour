{
  "parameters": {

    "roi_km": 50,
    "fill_value": -9999.0,

    "mask_points_by_reference_time": {
      "enabled": true
    },

    "interpolate_points": {
      "__comment__": "method: nearest {}, mean {}, idw {k_neighbours: 8, power: 1.5}",
      "enabled": true,
      "method": "idw",
      "parameters": {"k_neighbours": 8, "power": 1.5}
    },

    "interpolate_time": {
      "enabled": true,
      "method": "nearest",
      "parameters": {}
    },

    "mask_map_extension": {
      "enabled": true,
      "parameters": {"extension_pixels": 50}
    },

    "mask_map_boundary": {
      "enabled": true,
      "parameters": {"boundary_pixels": 15}
    },

    "smooth_map" : {
      "enabled": true,
      "method": "gaussian",
      "parameters": {
        "sigma": 2, "iterations": 2
      }
    },

    "convert_map": {
      "enabled": true,
      "method": "vwc_to_ssm",
      "parameters": {
        "units": "%", "clip_min": 0.0, "clip_max": 100.0, "fill_value": -9999.0
      }
    },

    "scale_map": {
      "enabled": false,
      "method": "min_max_scaling",
      "parameters" : {
        "variables": {
          "mean": "soil_moisture_mean", "std": "soil_moisture_std",
          "min": "soil_moisture_min", "max": "soil_moisture_max"
        },
      "units": "%", "clip_min": 0.0, "clip_max": 100.0, "fill_value": -9999.0
      }
    },

    "cell_list": null,
    "cell_digits": 4
  },

  "geo" : {
    "grid": {
      "name": "fibgrid_6.25",
      "max_distance_km": 25
    },
    "mask": {
      "folder": "/home/fabio/Desktop/recolour/dset/domain/",
      "filename": "grid_reference_250m_liguria.tiff",
      "mask_band": 1
    },
    "porosity": {
      "folder": "/home/fabio/Desktop/recolour/exec/soil/data/soil_grids/cells/",
      "filename": "soilgrids_cell_{cell:04d}.nc",
      "variable_name": "porosity_0_5cm_mean",
      "min_value": 0.05,
      "max_value": 0.90
    }
  },

  "metrics": {
    "folder": "/home/fabio/Desktop/recolour/dset/smap_metrics/cells/",
    "filename": "smap_metrics_cell_{cell:04d}.nc"
  },

  "source": {
    "folder": "/home/fabio/Desktop/recolour/dset/smap_cell_nrt/spl2smp_e/{time_step:%Y/%m/%d/}",
    "filename": "smap_{cell_n}_{time_step:%Y%m%d}.nc",
    "value_col": "soil_moisture",
    "variable_name": "soil_moisture"
  },
  "destination": {
    "folder": "/home/fabio/Desktop/recolour/exec/smap_cell_nrt/spl2smp_e/{time_step:%Y/%m/%d/}",
    "filename": "smap_liguria_{time_step:%Y%m%d}.tif",

    "variable_name": "surface_soil_moisture",
    "variable_name_interp": "surface_soil_moisture_interp",
    "variable_name_time_lag": "time_lag",

    "overwrite": true,
    "dry_run": false
  },

  "time": {
    "time_start": null,
    "time_end": null,
    "time_delta": "24H",
    "time_frequency": "1H",
    "floor_start_to_midnight": true,
    "floor_end_to_midnight": false,
    "floor_reference_to_offset": {"active": false, "days":"1D", "time": "23:00"}
  },
  "report": {
    "enabled": true,
    "folder": "/home/fabio/Desktop/recolour/exec/smap_cell_nrt/report/{time_step:%Y/%m/%d}",
    "filename": "cell2grid_smap_report_%Y%m%d_%H%M.json"
  },
    "logging": {
    "folder": "/home/fabio/Desktop/recolour/exec/smap_cell_nrt/log/{time_step:%Y/%m/%d}",
    "filename": "cell2grid_smap.log",
    "level": "INFO",
    "rotate_daily": true
  }
}